# ─── Runtime ────────────────────────────────────────────────
PORT=3030
NODE_ENV=development
DEBUG_MODE=true                 # exposes /debug and returns agent-trace on every reply

# ─── Database (libSQL — local file by default, Turso-compatible) ───
DB_URL=file:./data/sanad.db
# DB_URL=libsql://your-db.turso.io
# DB_AUTH_TOKEN=...

# ─── LLM provider ───────────────────────────────────────────
# 'anthropic' (default when ANTHROPIC_API_KEY is set) or 'qwen'.
# When unset and no key is available, the agent falls back to v1 heuristic mode.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# ─── Qwen (always required for embeddings — Anthropic has no embed API) ───
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024

# ─── Agent ───────────────────────────────────────────────────
SANAD_AGENT_V2=true             # false → v1 heuristic state machine (deterministic)
SANAD_SKIP_EMBED=               # 1 → disable background embedder (CI / no-key dev)

# ─── WhatsApp Cloud API (leave empty while testing via web) ───
# See docs/FACEBOOK_SETUP.md for the Meta Developer Console walkthrough.
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# App secret used to verify Meta-signed X-Hub-Signature-256 on inbound
# webhooks. When empty, signature verification is DISABLED (fine for local
# dev, never for production). Found at Meta App → Settings → Basic → App Secret.
WHATSAPP_APP_SECRET=

# ─── AmwalPay (not wired in v0) ────
AMWALPAY_MERCHANT_ID=
AMWALPAY_API_KEY=

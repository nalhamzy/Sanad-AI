{
  "name": "sanad-ai",
  "version": "0.1.0",
  "description": "One WhatsApp assistant for every Sanad service in Oman.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node seed.js",
    "seed:mock": "node seed-mock.js",
    "test": "node --test --test-concurrency=1 --test-reporter=spec tests/01-unit.test.js tests/02-catalogue.test.js tests/03-agent.test.js tests/04-routes.test.js",
    "test:unit": "node --test tests/01-unit.test.js tests/02-catalogue.test.js",
    "test:watch": "node --test --watch tests/01-unit.test.js tests/02-catalogue.test.js tests/03-agent.test.js tests/04-routes.test.js"
  },
  "engines": { "node": ">=18.17.0" },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "multer": "^2.0.1"
  }
}
